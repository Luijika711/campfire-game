[gd_scene load_steps=2 format=3 uid="uid://qr_display"]

[ext_resource type="Script" path="res://scripts/qr_display.gd" id="1_qr"]

[node name="QRDisplay" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_qr")

[node name="Panel" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 8
alignment = 1

[node name="TitleLabel" type="Label" parent="Panel"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(0.9, 0.8, 0.6, 1)
text = "Scan to Join"
horizontal_alignment = 1

[node name="QRPlaceholder" type="CenterContainer" parent="Panel"]
layout_mode = 2

[node name="QRBackground" type="ColorRect" parent="Panel/QRPlaceholder"]
custom_minimum_size = Vector2(250, 250)
layout_mode = 2
color = Color(1, 1, 1, 1)

[node name="QRTextureRect" type="TextureRect" parent="Panel/QRPlaceholder/QRBackground"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 5.0
offset_top = 5.0
offset_right = -5.0
offset_bottom = -5.0
grow_horizontal = 2
grow_vertical = 2
expand_mode = 1
stretch_mode = 5

[node name="URLLabel" type="Label" parent="Panel"]
layout_mode = 2
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.6, 0.6, 0.6, 1)
text = "URL will appear here"
horizontal_alignment = 1
autowrap_mode = 3

[node name="CopyButton" type="Button" parent="Panel"]
layout_mode = 2
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 14
text = "Copy URL"

[node name="StatusLabel" type="Label" parent="Panel"]
layout_mode = 2
theme_override_font_sizes/font_size = 12
theme_override_colors/font_color = Color(0.7, 0.7, 0.7, 1)
text = "Waiting for players..."
horizontal_alignment = 1

[node name="HTTPRequest" type="HTTPRequest" parent="."]

[connection signal="pressed" from="Panel/CopyButton" to="." method="_on_copy_url_pressed"]
