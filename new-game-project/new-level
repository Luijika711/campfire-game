#!/usr/bin/env python3
"""
New Level Generator for Godot Project (Interactive)
Creates new levels by duplicating existing ones or from a template.
Supports parallax background selection and hue-shift color overlay.
"""

import os
import re
import sys
from pathlib import Path

# Project paths
PROJECT_ROOT = Path(__file__).parent
LEVELS_DIR = PROJECT_ROOT / "scenes" / "levels"
TEMPLATE_LEVEL = LEVELS_DIR / "basic" / "level.tscn"
WALLPAPERS_DIR = PROJECT_ROOT / "assets" / "wallpapers"

# Filenames to exclude from parallax layers (source/reference images)
LAYER_EXCLUDE_STEMS = {"orig", "orig_big"}


def _find_layer_pngs(directory):
    """Find PNG files suitable as parallax layers in a directory."""
    return [
        f.name for f in directory.iterdir()
        if f.suffix.lower() == ".png" and f.stem not in LAYER_EXCLUDE_STEMS
    ]


def _natural_sort_key(filename):
    """Sort key for natural ordering (numeric first, then alphabetic)."""
    stem = Path(filename).stem
    match = re.match(r'^(\d+)', stem)
    if match:
        return (0, int(match.group(1)), stem)
    return (1, 0, stem.lower())


def _make_display_name(dir_name):
    """Generate a human-friendly display name from a directory name."""
    name = dir_name.replace("_", " ").replace("-", " ")
    cleaned = re.sub(r'\b[Pp]aralax\b', '', name)
    cleaned = re.sub(r'\b[Pp]arallax\b', '', cleaned)
    cleaned = re.sub(r'\b[Bb]ackgrounds?\b', '', cleaned)
    cleaned = cleaned.strip()
    if len(cleaned) < 2:
        return name.title()
    return cleaned.title()


def discover_parallax_packs():
    """Dynamically discover parallax packs from the wallpapers directory."""
    if not WALLPAPERS_DIR.exists():
        return {}

    packs = {}
    for pack_dir in sorted(WALLPAPERS_DIR.iterdir()):
        if not pack_dir.is_dir():
            continue

        pack_name = pack_dir.name
        subdir = ""

        png_files = _find_layer_pngs(pack_dir)

        # If no PNGs found, check one level of subdirectories
        if not png_files:
            for sub in sorted(pack_dir.iterdir()):
                if sub.is_dir():
                    png_files = _find_layer_pngs(sub)
                    if png_files:
                        subdir = sub.name
                        break

        if not png_files:
            continue

        png_files.sort(key=_natural_sort_key)

        # Auto-distribute motion scales: 0.0 (static background) to 0.9 (foreground)
        n = len(png_files)
        layers = []
        for i, filename in enumerate(png_files):
            scale = 0.0 if n == 1 else round(0.9 * i / (n - 1), 2)
            layers.append((filename, scale, scale))

        packs[pack_name] = {
            "display_name": _make_display_name(pack_name),
            "subdir": subdir,
            "image_width": 1920,
            "layers": layers,
        }

    return packs

# Color presets: name -> hue_shift value
COLOR_PRESETS = [
    ("Neutral (original colors)", 0.0),
    ("Green",                     0.15),
    ("Amber / Gold",              0.3),
    ("Orange",                    0.4),
    ("Red / Magenta",             0.55),
    ("Purple",                    0.75),
    ("Pink / Violet",             0.85),
]

def clear_screen():
    """Clear the terminal screen."""
    os.system('clear' if os.name != 'nt' else 'cls')

def print_header():
    """Print the script header."""
    print("=" * 60)
    print("       NEW LEVEL GENERATOR FOR GODOT PROJECT")
    print("=" * 60)
    print()

def get_existing_levels():
    """Get list of existing level directories."""
    if not LEVELS_DIR.exists():
        return []
    return sorted([d.name for d in LEVELS_DIR.iterdir() if d.is_dir()])

def generate_uid():
    """Generate a random unique ID for Godot nodes."""
    import random
    return random.randint(100000000, 999999999)

def replace_uids(content):
    """Replace UIDs in the content with new ones."""
    def replace_id(match):
        return f"unique_id={generate_uid()}"
    
    content = re.sub(r'unique_id=\d+', replace_id, content)
    
    # Also need to update the scene UID at the top
    uid_pattern = r'\[gd_scene format=3 uid="uid://([a-z0-9]+)"'
    
    def replace_scene_uid(match):
        import random
        import string
        new_uid = ''.join(random.choices(string.ascii_lowercase + string.digits, k=13))
        return f'[gd_scene format=3 uid="uid://{new_uid}"'
    
    content = re.sub(uid_pattern, replace_scene_uid, content)
    
    return content

def get_uid_from_import(image_path):
    """Read the UID from a Godot .import file."""
    import_file = Path(str(image_path) + ".import")
    if not import_file.exists():
        return None
    for line in import_file.read_text().splitlines():
        if line.startswith("uid="):
            # uid="uid://xxxxx"
            match = re.search(r'"(uid://[^"]+)"', line)
            if match:
                return match.group(1)
    return None

def get_available_parallax_packs():
    """Discover available parallax packs from the wallpapers directory."""
    return discover_parallax_packs()

def select_parallax():
    """Let user select a parallax background pack."""
    packs = get_available_parallax_packs()
    
    print("\n  Available parallax backgrounds:")
    print(f"    0. None (flat background)")
    options = list(packs.items())
    for i, (pack_name, pack_info) in enumerate(options, 1):
        layer_count = len(pack_info["layers"])
        print(f"    {i}. {pack_info['display_name']}  ({pack_name}, {layer_count} layers)")
    
    while True:
        choice = input(f"\n  Select parallax (0-{len(options)}, Enter for 1): ").strip()
        if not choice:
            choice = "1"
        if choice == "0":
            return None, None
        if choice.isdigit():
            idx = int(choice) - 1
            if 0 <= idx < len(options):
                pack_name, pack_info = options[idx]
                return pack_name, pack_info
        print(f"  Invalid choice. Enter 0-{len(options)}")

def select_color():
    """Let user select a color overlay (hue shift)."""
    print("\n  Color overlay (hue-shifts the background):")
    for i, (name, value) in enumerate(COLOR_PRESETS):
        marker = " ←" if value == 0.0 else ""
        print(f"    {i}. {name} ({value}){marker}")
    print(f"    {len(COLOR_PRESETS)}. Custom value (0.0 - 1.0)")
    
    while True:
        choice = input(f"\n  Select color (0-{len(COLOR_PRESETS)}, Enter for 0): ").strip()
        if not choice:
            return 0.0
        if choice.isdigit():
            idx = int(choice)
            if 0 <= idx < len(COLOR_PRESETS):
                return COLOR_PRESETS[idx][1]
            if idx == len(COLOR_PRESETS):
                while True:
                    val = input("  Enter hue value (0.0 - 1.0): ").strip()
                    try:
                        v = float(val)
                        if 0.0 <= v <= 1.0:
                            return v
                    except ValueError:
                        pass
                    print("  Invalid. Enter a number between 0.0 and 1.0")
        print(f"  Invalid choice. Enter 0-{len(COLOR_PRESETS)}")

def build_parallax_ext_resources(pack_name, pack_info):
    """Build ext_resource lines for a parallax pack."""
    lines = []
    pack_dir = WALLPAPERS_DIR / pack_name
    if pack_info["subdir"]:
        pack_dir = pack_dir / pack_info["subdir"]
    
    res_prefix = f"res://assets/wallpapers/{pack_name}"
    if pack_info["subdir"]:
        res_prefix += f"/{pack_info['subdir']}"
    
    for i, (filename, _, _) in enumerate(pack_info["layers"]):
        image_path = pack_dir / filename
        uid = get_uid_from_import(image_path)
        uid_str = f' uid="{uid}"' if uid else ""
        res_id = f"px_{i+1}"
        lines.append(
            f'[ext_resource type="Texture2D"{uid_str} '
            f'path="{res_prefix}/{filename}" id="{res_id}"]'
        )
    return "\n".join(lines)

def build_parallax_nodes(pack_info):
    """Build ParallaxBackground + ParallaxLayer node definitions."""
    w = pack_info["image_width"]
    lines = []
    lines.append(f'[node name="ParallaxBackground" type="ParallaxBackground" parent="."]')
    
    for i, (filename, mx, my) in enumerate(pack_info["layers"]):
        layer_name = Path(filename).stem.replace(".", "_")
        lines.append(f'')
        lines.append(f'[node name="Layer{i+1}_{layer_name}" type="ParallaxLayer" parent="ParallaxBackground"]')
        lines.append(f'motion_scale = Vector2({mx}, {my})')
        lines.append(f'motion_mirroring = Vector2({w}, 0)')
        lines.append(f'')
        lines.append(f'[node name="Sprite2D" type="Sprite2D" parent="ParallaxBackground/Layer{i+1}_{layer_name}"]')
        lines.append(f'texture = ExtResource("px_{i+1}")')
    
    return "\n".join(lines)

def update_level_name(content, name):
    """Update the level name in the content."""
    # Convert snake_case or kebab-case to Title Case
    display_name = name.replace('_', ' ').replace('-', ' ').title()
    content = re.sub(r'level_name = "[^"]*"', f'level_name = "{display_name}"', content)
    return content

def validate_level_name(name):
    """Validate the level name."""
    if not name:
        return False, "Name cannot be empty"
    if not re.match(r'^[a-zA-Z][a-zA-Z0-9_-]*$', name):
        return False, "Name must start with a letter and contain only letters, numbers, underscores, and hyphens"
    if (LEVELS_DIR / name).exists():
        return False, f"Level '{name}' already exists"
    return True, None

def create_level_from_template(name, template_path=None, parallax_pack=None, parallax_info=None, hue_shift=0.0):
    """Create a new level by copying from a template."""
    template_path = template_path or TEMPLATE_LEVEL
    
    if not template_path.exists():
        print(f"Error: Template not found at {template_path}")
        return False
    
    # Create level directory
    level_dir = LEVELS_DIR / name
    level_dir.mkdir(parents=True)
    
    # Read template
    with open(template_path, 'r') as f:
        content = f.read()
    
    # Replace UIDs and update name
    content = replace_uids(content)
    content = update_level_name(content, name)
    
    # Update node name (only root node - doesn't have parent=".")
    node_name = name.replace('_', ' ').replace('-', ' ').title().replace(' ', '')
    content = re.sub(r'\[node name="[^"]*" type="Node2D"(?! parent="\.")', f'[node name="Level{node_name}" type="Node2D"', content)
    
    # Inject parallax background (replace old Background node if present)
    if parallax_pack and parallax_info:
        # Remove old wallpaper ext_resource
        content = re.sub(r'\[ext_resource[^\]]*wallpaper[^\]]*\]\n?', '', content)
        
        # Add parallax ext_resources before the first sub_resource
        px_resources = build_parallax_ext_resources(parallax_pack, parallax_info)
        content = content.replace(
            '\n[sub_resource',
            f'\n{px_resources}\n\n[sub_resource',
            1
        )
        
        # Replace old Background node with ParallaxBackground
        px_nodes = build_parallax_nodes(parallax_info)
        bg_pattern = r'\[node name="Background"[^\[]*'
        if re.search(bg_pattern, content):
            content = re.sub(bg_pattern, px_nodes + '\n\n', content)
        else:
            # Insert ParallaxBackground before TileMap
            content = content.replace(
                '[node name="TileMap"',
                px_nodes + '\n\n[node name="TileMap"'
            )
    
    # Inject hue shift property
    if hue_shift != 0.0:
        content = re.sub(
            r'(description = "[^"]*")',
            rf'\1\nbackground_hue_shift = {hue_shift}',
            content
        )
    
    # Write new level
    level_file = level_dir / "level.tscn"
    with open(level_file, 'w') as f:
        f.write(content)
    
    return True

