def list_levels():
    """List all existing levels."""
    levels = get_existing_levels()
    if not levels:
        print("No levels found.")
        return
    
    print("\nExisting levels:")
    for i, level in enumerate(levels, 1):
        level_file = LEVELS_DIR / level / "level.tscn"
        if level_file.exists():
            print(f"  {i}. {level}")
        else:
            print(f"  {i}. {level} (no level.tscn)")
    print()
    return levels

def select_template():
    """Let user select a template level."""
    levels = list_levels()
    
    if not levels:
        print("No templates available!")
        return None
    
    while True:
        choice = input("Select a template level (number or name, Enter for 'basic'): ").strip()
        
        if not choice:
            return TEMPLATE_LEVEL
        
        # Check if it's a number
        if choice.isdigit():
            idx = int(choice) - 1
            if 0 <= idx < len(levels):
                return LEVELS_DIR / levels[idx] / "level.tscn"
            else:
                print(f"Invalid number. Please enter 1-{len(levels)}")
                continue
        
        # Check if it's a name
        if choice in levels:
            return LEVELS_DIR / choice / "level.tscn"
        
        print(f"Level '{choice}' not found. Try again.")

def prompt_for_level_name():
    """Prompt user for a level name."""
    while True:
        name = input("\nEnter level name (snake_case recommended): ").strip()
        
        valid, error = validate_level_name(name)
        if valid:
            return name
        else:
            print(f"  Error: {error}")

def show_main_menu():
    """Show the main menu and get user choice."""
    print("\nWhat would you like to do?")
    print("  1. Create new level from template")
    print("  2. Create empty level (minimal structure)")
    print("  3. List existing levels")
    print("  4. Exit")
    
    while True:
        choice = input("\nEnter choice (1-4): ").strip()
        if choice in ['1', '2', '3', '4']:
            return choice
        print("Invalid choice. Please enter 1, 2, 3, or 4.")

def main():
    clear_screen()
    print_header()
    
    # Check if levels directory exists
    if not LEVELS_DIR.exists():
        print(f"Error: Levels directory not found at {LEVELS_DIR}")
        print("Please run this script from the project root.")
        return 1
    
    while True:
        choice = show_main_menu()
        
        if choice == '1':
            # Create from template
            print("\n" + "-" * 60)
            print("Create level from template")
            print("-" * 60)
            
            template_path = select_template()
            if not template_path:
                continue
            
            level_name = prompt_for_level_name()
            
            print(f"\nCreating level '{level_name}' from template...")
            if create_level_from_template(level_name, template_path):
                print(f"\n✓ SUCCESS! Created new level: {level_name}")
                print(f"  Location: scenes/levels/{level_name}/level.tscn")
                print("\nNext steps:")
                print(f"  1. Open Godot and load: res://scenes/levels/{level_name}/level.tscn")
                print(f"  2. Edit the level in the editor")
            else:
                print("\n✗ Failed to create level.")
        
        elif choice == '2':
            # Create empty level
            print("\n" + "-" * 60)
            print("Create empty level")
            print("-" * 60)
            
            level_name = prompt_for_level_name()
            
            print(f"\nCreating empty level '{level_name}'...")
            if create_empty_level(level_name):
                print(f"\n✓ SUCCESS! Created empty level: {level_name}")
                print(f"  Location: scenes/levels/{level_name}/level.tscn")
                print("\nNext steps:")
                print(f"  1. Open Godot and load: res://scenes/levels/{level_name}/level.tscn")
                print(f"  2. Add tiles, spawn points, coins, etc.")
            else:
                print("\n✗ Failed to create level.")
        
        elif choice == '3':
            # List levels
            list_levels()
        
        elif choice == '4':
            # Exit
            print("\nGoodbye!")
            return 0
        
        input("\nPress Enter to continue...")
        clear_screen()
        print_header()

if __name__ == '__main__':
    sys.exit(main())
