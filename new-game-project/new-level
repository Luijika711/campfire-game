#!/usr/bin/env python3
"""
New Level Generator for Godot Project (Interactive)
Creates new levels by duplicating existing ones or from a template.
"""

import os
import re
import sys
from pathlib import Path

# Project paths
PROJECT_ROOT = Path(__file__).parent
LEVELS_DIR = PROJECT_ROOT / "scenes" / "levels"
TEMPLATE_LEVEL = LEVELS_DIR / "basic" / "level.tscn"

def clear_screen():
    """Clear the terminal screen."""
    os.system('clear' if os.name != 'nt' else 'cls')

def print_header():
    """Print the script header."""
    print("=" * 60)
    print("       NEW LEVEL GENERATOR FOR GODOT PROJECT")
    print("=" * 60)
    print()

def get_existing_levels():
    """Get list of existing level directories."""
    if not LEVELS_DIR.exists():
        return []
    return sorted([d.name for d in LEVELS_DIR.iterdir() if d.is_dir()])

def generate_uid():
    """Generate a random unique ID for Godot nodes."""
    import random
    return random.randint(100000000, 999999999)

def replace_uids(content):
    """Replace UIDs in the content with new ones."""
    def replace_id(match):
        return f"unique_id={generate_uid()}"
    
    content = re.sub(r'unique_id=\d+', replace_id, content)
    
    # Also need to update the scene UID at the top
    uid_pattern = r'\[gd_scene format=3 uid="uid://([a-z0-9]+)"'
    
    def replace_scene_uid(match):
        import random
        import string
        new_uid = ''.join(random.choices(string.ascii_lowercase + string.digits, k=13))
        return f'[gd_scene format=3 uid="uid://{new_uid}"'
    
    content = re.sub(uid_pattern, replace_scene_uid, content)
    
    return content

def update_level_name(content, name):
    """Update the level name in the content."""
    # Convert snake_case or kebab-case to Title Case
    display_name = name.replace('_', ' ').replace('-', ' ').title()
    content = re.sub(r'level_name = "[^"]*"', f'level_name = "{display_name}"', content)
    return content

def validate_level_name(name):
    """Validate the level name."""
    if not name:
        return False, "Name cannot be empty"
    if not re.match(r'^[a-zA-Z][a-zA-Z0-9_-]*$', name):
        return False, "Name must start with a letter and contain only letters, numbers, underscores, and hyphens"
    if (LEVELS_DIR / name).exists():
        return False, f"Level '{name}' already exists"
    return True, None

def create_level_from_template(name, template_path=None):
    """Create a new level by copying from a template."""
    template_path = template_path or TEMPLATE_LEVEL
    
    if not template_path.exists():
        print(f"Error: Template not found at {template_path}")
        return False
    
    # Create level directory
    level_dir = LEVELS_DIR / name
    level_dir.mkdir(parents=True)
    
    # Read template
    with open(template_path, 'r') as f:
        content = f.read()
    
    # Replace UIDs and update name
    content = replace_uids(content)
    content = update_level_name(content, name)
    
    # Update node name (only root node - doesn't have parent=".")
    node_name = name.replace('_', ' ').replace('-', ' ').title().replace(' ', '')
    content = re.sub(r'\[node name="[^"]*" type="Node2D"(?! parent="\.")', f'[node name="Level{node_name}" type="Node2D"', content)
    
    # Write new level
    level_file = level_dir / "level.tscn"
    with open(level_file, 'w') as f:
        f.write(content)
    
    return True

